# Required database settings
POSTGRES_USER=bandival
POSTGRES_PASSWORD=change-me-strong

# Required app secret (min 32 chars random)
AUTH_SECRET=replace-with-long-random-secret

# Runtime and URL
APP_PORT=3000
APP_BASE_URL=https://bandival.example.com
COOKIE_SECURE=true

# Image source
BANDIVAL_IMAGE=ghcr.io/f0up/bandival-web
BANDIVAL_TAG=latest

# SMTP (optional but recommended for invites/notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Bandival <noreply@bandival.example.com>
